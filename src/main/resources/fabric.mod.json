{
	"schemaVersion": 1,
	"id": "nexus-client",
	"version": "${version}",
	"name": "Nexus Client",
	"description": "A Fabric utility client with a custom menu, click GUI, HUD modules, and in-game configuration.",
	"authors": [
		"Zigliix"
	],
	"contact": {},
	"license": "CC0-1.0",
	"icon": "assets/nexus-client/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"nexus.zigliix.com.NexusClient"
		],
		"client": [
			"nexus.zigliix.com.client.NexusClientClient"
		]
	},
	"mixins": [
		{
			"config": "nexus-client.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}
